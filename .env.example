# Yandex Disk authentication
YA_TOKEN=your_yandex_disk_oauth_token_here

# Crypto settings
SALT_SIZE=32
ITERATIONS=100000
ROUNDS=3

# Yandex Disk paths
REMOTE_PATH=/Приложения/cesar-len-key/vault.enc
# BACKUP_REMOTE_PATH не требуется - вычисляется как REMOTE_PATH + ".backup"
# Если указан явно, будет использоваться вместо вычисленного значения
