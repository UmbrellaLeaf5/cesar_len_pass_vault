#:kivy 2.3

<VaultScreen>:
  editor: editor
  backup_editor: backup_editor
  status_label: status_label
  toolbar: toolbar

  BoxLayout:
    orientation: "vertical"
    padding: 4
    spacing: 4

    Toolbar:
      id: toolbar
      size_hint_y: None
      height: 48
      download_enabled: root._state.value in ("empty", "loaded", "split")
      upload_enabled: root._state.value in ("loaded", "split")
      add_enabled: root._state.value in ("loaded", "split")

      BoxLayout:
        spacing: 4
        padding: 2

        CustomButton:
          text: "Download"
          disabled: not toolbar.download_enabled
          opacity: 1 if toolbar.download_enabled else 0.4
          on_release: root.download()

        CustomButton:
          text: "Upload"
          disabled: not toolbar.upload_enabled
          opacity: 1 if toolbar.upload_enabled else 0.4
          on_release: root.upload()

        CustomButton:
          text: "+ Entry"
          disabled: not toolbar.add_enabled
          opacity: 1 if toolbar.add_enabled else 0.4
          on_release: root.add_entry()

        CustomButton:
          text: "*"
          font_size: 20
          width: 48
          size_hint_x: None
          on_release: root.open_settings()

    BoxLayout:
      orientation: "horizontal"

      CustomTextInput:
        id: editor
        text: ""
        readonly: True
        background_color: 0.1, 0.1, 0.1, 1
        foreground_color: 1.0, 1.0, 1.0, 1

      CustomTextInput:
        id: backup_editor
        text: ""
        readonly: True
        background_color: 0.1, 0.1, 0.1, 1
        foreground_color: 1.0, 1.0, 1.0, 1
        size_hint_x: 0
        opacity: 0

    CustomLabel:
      id: status_label
      text: "Not loaded"
      font_size: 15
      color: 0.6, 0.6, 0.6, 1
      size_hint_y: None
      height: 28
      halign: "left"
      valign: "middle"
