#:kivy 2.3

<UnlockScreen>:
  password_input: password_input
  error_label: error_label

  BoxLayout:
    orientation: "vertical"
    padding: 40
    spacing: 20

    canvas.before:
      Color:
        rgba: root._bg_color
      Rectangle:
        pos: self.pos
        size: self.size

    Widget:
      size_hint_y: 1

    CustomLabel:
      text: "CesarLen PassVault"
      font_size: 28
      halign: "center"
      size_hint_y: None
      height: 50

    CustomLabel:
      text: "Master Password"
      halign: "left"
      size_hint_y: None
      height: 24

    CustomTextInput:
      id: password_input
      password: True
      multiline: False
      size_hint_y: None
      height: 48
      on_text_validate: root.unlock()

    CustomLabel:
      id: error_label
      text: ""
      color: 1.0, 0.3, 0.3, 1
      opacity: 0
      halign: "center"
      size_hint_y: None
      height: 24

    CustomButton:
      text: "Unlock"
      on_release: root.unlock()

    Widget:
      size_hint_y: 1
